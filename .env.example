# ── API Keys (add only what you use) ─────────────────────────────────────────
# NOTE: With DB model management, API keys go into the UI — not here.
# These are only needed for models defined in localforge.json (legacy).
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# ── Database ──────────────────────────────────────────────────────────────────
# Leave empty to use local SQLite (./localforge.db) — fine for personal use.
# Set to a MySQL URL to use MySQL (required for multi-user/server deployments).
# DATABASE_URL=mysql://user:password@localhost:3306/localforge

# ── Security ──────────────────────────────────────────────────────────────────
# Uncomment to require an API key to access LocalForge (recommended on servers).
# API_KEY=change-me-please

# ── App ───────────────────────────────────────────────────────────────────────
LOCALFORGE_HOST=127.0.0.1
LOCALFORGE_PORT=8000
LOCALFORGE_CONFIG=./localforge.json

# ── Production (nginx) ────────────────────────────────────────────────────────
# CORS_ORIGINS=https://yourdomain.com
