# ── Autenticación ─────────────────────────────────────────────────────────────
# Clave de acceso al panel. Déjala vacía para modo abierto (solo local).
API_KEY=cambia-esto-por-una-clave-segura

# ── Base de datos ─────────────────────────────────────────────────────────────
# Por defecto: SQLite en el volumen /data (dentro del contenedor).
# Para usar MySQL descomenta y ajusta:
# DATABASE_URL=mysql://usuario:contraseña@host:3306/localforge

# ── Servidor ──────────────────────────────────────────────────────────────────
# No cambiar en Docker — el contenedor ya escucha en 0.0.0.0:8000
# LOCALFORGE_HOST=0.0.0.0
# LOCALFORGE_PORT=8000

# ── Telegram bot (opcional) ───────────────────────────────────────────────────
# Se puede configurar también desde Settings en la UI
# TELEGRAM_BOT_TOKEN=
